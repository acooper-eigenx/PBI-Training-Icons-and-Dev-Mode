table __Measures
	lineageTag: 525afd49-e773-4a6d-8646-1eb913449e24

	measure Avg_Sat_Score = AVERAGE(Hospital_ER_Data_20240826[patient_sat_score]) + 1
		lineageTag: 5ce1909b-fa1e-4ee5-ab5c-b343c04819d5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Avg_Wait_Time = AVERAGE(Hospital_ER_Data_20240826[patient_waittime])
		lineageTag: 5ce1909b-fa1e-4ee5-ab5c-b343c04819d6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Image_Sat =
			
			SWITCH(
			    TRUE(),
			    [Avg_Sat_Score] >= 7.5, "data:image/png;base64,",
			
			
			    [Avg_Sat_Score] >= 5, "data:image/png;base64,",
			
			
			    [Avg_Sat_Score] >= 2.5, "data:image/png;base64,",
			
			
			    "data:image/png;base64,"
			)
		lineageTag: b551ba48-08d6-4e76-a64c-fd0f5781d19c
		dataCategory: ImageUrl

	measure Icon_Satisfaction =
			
			SWITCH(
			    TRUE(),
			    [Avg_Sat_Score] >= 7.5, "Icon_Great",
			
			
			    [Avg_Sat_Score] >= 5, "Icon_Good",
			
			
			    [Avg_Sat_Score] >= 2.5, "Icon_Ok",
			
			
			    "Icon_Bad"
			)
		lineageTag: f5113a2d-dbe1-439f-a825-9b70eb19e420
		dataCategory: ImageUrl

	column _
		dataType: string
		lineageTag: 5277924e-7638-4af2-8913-ec01a85ad7ff
		summarizeBy: none
		sourceColumn: _

		annotation SummarizationSetBy = Automatic

	partition __Measures = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [_ = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"_", type text}})
				in
				    #"Changed Type"

	annotation PBI_ResultType = Table

